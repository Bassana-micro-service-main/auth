# ===============================
# APP
# ===============================
NODE_ENV=development
APP_NAME=auth-service
PORT=3000

# ===============================
# DATABASE
# ===============================
DB_HOST=auth-db-dev
DB_PORT=5432
DB_NAME=auth-db
DB_USER=postgres
DB_PASSWORD=postgres

DATABASE_URL="postgresql://postgres:postgres@auth-db-dev:5432/auth-db"

# ===============================
# POSTGRES (CONTAINER)
# ===============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=user_profile-db

# ===============================
# SECURITY / AUTH
# ===============================
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=1h

# ===============================
# API / GATEWAY
# ===============================
API_PREFIX=/api
API_GATEWAY_URL=http://gateway:3000

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=debug

# ===============================
# FEATURE FLAGS
# ===============================
ENABLE_SWAGGER=true


PRISMA_CLIENT_ENGINE_TYPE=binary