# Spring Boot — variables pour docker-compose standalone (stack : voir docker-compose.dev-stack.yml)
# ===============================
# APP
# ===============================
NODE_ENV=development
APP_NAME=auth-service
PORT=8100

# ===============================
# DATABASE
# ===============================
DB_HOST=auth-db-dev
DB_PORT=5432
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@auth-db-dev:5432/auth_db

# ===============================
# POSTGRES (CONTAINER)
# ===============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth_db

# ===============================
# SECURITY / AUTH
# ===============================
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=1h

# ===============================
# API / GATEWAY
# ===============================
API_PREFIX=/api
API_GATEWAY_URL=http://api-gateway:8080
AUDIT_SERVICE_URL=http://audit-service:8300

# ===============================
# USER PROFILE (register / login)
# ===============================
AUTH_USER_PROFILE_BASE_URL=http://user_profile-service:8200

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=debug

# ===============================
# FEATURE FLAGS
# ===============================
ENABLE_SWAGGER=true
